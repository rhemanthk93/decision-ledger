# Copy this file to .env.local, fill in the values, restart `pnpm dev`.
# Keep the file ASCII-only - Next.js's dotenv parser silently drops every
# line after a non-ASCII character such as an em dash or a curly quote.

# Supabase - safe to expose, browser-side client reads these.
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Python backend - where the Refresh button POSTs /admin/run-pipeline.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Anthropic - server-side only, used by the Next.js /api/query route
# (the "Ask Claude" chat bar). Same value as backend/.env's ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=sk-ant-api03-...
